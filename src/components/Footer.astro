---
import Newsletter from "./Newsletter.astro";

interface MenuItem { url: string; label: string; children?: MenuItem[] }
interface Menu { items: MenuItem[] }
interface Props {
	menu: Menu | null;
	siteTitle: string;
	siteTagline: string;
}
const { menu, siteTitle, siteTagline } = Astro.props;
const year = new Date().getFullYear();
---
<Newsletter />

<footer class="site-footer">
	<div class="container">
		<div class="footer-grid">
			<div class="footer-brand">
				<h3>{siteTitle}</h3>
				<p>{siteTagline}. Small-batch essentials for apparel and home, designed in Lisbon.</p>
			</div>

			<div class="footer-col">
				<h4>Shop</h4>
				<ul>
					<li><a href="/shop">All products</a></li>
					<li><a href="/category/apparel">Apparel</a></li>
					<li><a href="/category/home">Home</a></li>
					<li><a href="/category/accessories">Accessories</a></li>
				</ul>
			</div>

			<div class="footer-col">
				<h4>Help</h4>
				<ul>
					{menu?.items.map((item) => (
						<li><a href={item.url}>{item.label}</a></li>
					))}
				</ul>
			</div>

			<div class="footer-col">
				<h4>Follow</h4>
				<ul>
					<li><a href="#" rel="noopener">Instagram</a></li>
					<li><a href="#" rel="noopener">Pinterest</a></li>
					<li><a href="#" rel="noopener">Journal</a></li>
					<li><a href="/rss.xml">RSS</a></li>
				</ul>
			</div>
		</div>

		<div class="footer-bottom">
			<span>&copy; {year} {siteTitle}. All rights reserved.</span>
			<span>Demo template &middot; Not a functional store</span>
		</div>
	</div>
</footer>
