		"pages": [
			{
				"id": "page-about",
				"slug": "about",
				"status": "published",
				"data": {
					"title": "About Kin & Stone",
					"content": [
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "Quiet goods for everyday use" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Kin & Stone is a small design studio based in Lisbon, Portugal. We make a tight collection of apparel and home goods in natural fibers, working with a handful of workshops we know personally." }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "We believe in fewer, better things — made honestly, priced fairly, and designed to last for years rather than seasons. Our collection grows slowly on purpose." }] },
						{ "_type": "block", "style": "h3", "children": [{ "_type": "span", "text": "How we work" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Every piece we sell is developed with a specific maker — a family atelier outside Porto, a 150-year-old mill in France, a ceramics studio in Seto, Japan. We visit regularly. We pay fairly. We don't rush." }] },
						{ "_type": "block", "style": "blockquote", "children": [{ "_type": "span", "text": "Good design is as little design as possible. We try to live by this." }] },
						{ "_type": "block", "style": "h3", "children": [{ "_type": "span", "text": "Demo template notice" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "This site is a demonstration of the Kin & Stone shop template for EmDash CMS. The cart and checkout are decorative — connect your own payment provider to enable real transactions." }] }
					]
				}
			},
			{
				"id": "page-shipping-returns",
				"slug": "shipping-returns",
				"status": "published",
				"data": {
					"title": "Shipping & Returns",
					"content": [
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "Shipping" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "We ship worldwide from our studio in Lisbon. Orders are packed within two business days and shipped via tracked services. Free standard shipping on orders over $120 within the EU and US." }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Standard EU delivery takes 3–6 business days. International delivery takes 5–10 business days, subject to customs. We ship in 100% recycled, plastic-free packaging." }] },
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "Returns" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Not quite right? You have 30 days from delivery to return unworn items in their original packaging for a full refund or exchange. We cover return shipping within the EU; international returns are the customer's responsibility." }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "To start a return, email us at studio@kinandstone.example with your order number. Sale items can be exchanged but are final sale." }] }
					]
				}
			},
			{
				"id": "page-faq",
				"slug": "faq",
				"status": "published",
				"data": {
					"title": "Frequently Asked Questions",
					"content": [
						{ "_type": "block", "style": "h3", "children": [{ "_type": "span", "text": "Where is Kin & Stone made?" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Apparel is made primarily in Portugal, with select pieces knit in Italy and Japan. Ceramics are thrown in Japan and Portugal. Leather goods are made in Tuscany, Italy." }] },
						{ "_type": "block", "style": "h3", "children": [{ "_type": "span", "text": "How should I care for linen?" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Machine wash cold on a gentle cycle, line dry if possible. A warm iron works if you prefer a crisper look, but linen's natural wrinkle is part of its charm." }] },
						{ "_type": "block", "style": "h3", "children": [{ "_type": "span", "text": "Do you restock sold-out items?" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Most core pieces are restocked within 4–8 weeks. Limited editions are produced once and never repeated. Sign up for restock notifications on the product page." }] },
						{ "_type": "block", "style": "h3", "children": [{ "_type": "span", "text": "Is this a real store?" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Kin & Stone is the demo brand for the EmDash Shop template. The cart is decorative and no real payments are processed. If you're building your own store on this template, connect a payment provider (Stripe, Snipcart, or Shopify Buy Buttons) to enable checkout." }] }
					]
				}
			},
			{
				"id": "page-journal",
				"slug": "journal",
				"status": "published",
				"data": {
					"title": "Studio Journal",
					"content": [
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "Notes from the studio" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "A slower record of what we're working on, what we're reading, and the makers we're visiting. Updated when we have something worth saying." }] },
						{ "_type": "block", "style": "blockquote", "children": [{ "_type": "span", "text": "We'd rather publish once a month about something that matters than every day about nothing in particular." }] }
					]
				}
			}
		]
